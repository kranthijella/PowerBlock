# Keep the build context small and reproducible. The frontend is built fresh inside
# the image, so local node_modules / build output and committed dist are not needed.
.git
.idea
.vscode
bin/
*.db
*.sqlite
*.sqlite3

web/node_modules
web/dist
**/*.tsbuildinfo

# The embedded dist is regenerated by the node stage and overlaid into the go stage,
# so the committed copy is excluded to avoid shipping stale assets.
internal/httpapi/web/dist